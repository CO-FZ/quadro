# ──────────────────────────────────────────────────────────────────────────────
# .gitignore — Quadro CO-FZ
# Rastreamos apenas o que é necessário para rodar a aplicação em produção
# e a documentação do projeto (docs/).
# ──────────────────────────────────────────────────────────────────────────────

# ── Dependências ──────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Build / Next.js ───────────────────────────────────────────────────────────
/.next/
/out/
/build

# ── TypeScript cache ──────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Variáveis de ambiente (nunca commitar valores reais) ──────────────────────
.env*
!.env*.example

# ── Logs de debug ─────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Cobertura de testes e artefatos temporários ───────────────────────────────
/coverage
test_output*.txt

# Pasta do Antigravity (dados do agente — nunca commitar)
.gemini/

# Skills locais do projeto (não são código da aplicação)
/skills/

# Configuração de outros agentes de IA
/.agents/
.codex

# ── Misc ──────────────────────────────────────────────────────────────────────
.DS_Store
*.pem
.vercel
