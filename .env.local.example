# Variáveis de ambiente para desenvolvimento local (copie para .env.local).
# .env.local é ignorado pelo git — NUNCA commite valores reais aqui.
#
# Onde obter: Supabase Dashboard → Project Settings → API.

# URL pública do projeto Supabase (vai para o bundle do browser).
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Chave publishable/anon do Supabase (pública por design).
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Opcional: link da planilha do Google Sheets exibido na /matriz.
# Deixe vazio para esconder o botão "Abrir no Google Sheets".
NEXT_PUBLIC_GOOGLE_SHEET_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Somente para rodar os testes locais (integration/e2e) com Supabase local.
# Obtenha rodando `supabase start` e depois `supabase status`.
# NÃO são usados pelo app em runtime nem precisam ir para a Vercel.
# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
